FROM node:22-slim

# Install Python for the MOB adapter
RUN apt-get update && apt-get install -y --no-install-recommends python3 python3-pip python3-venv && \
    rm -rf /var/lib/apt/lists/*

# Install Pi coding agent
RUN npm install -g @mariozechner/pi-coding-agent

# Install adapter dependencies
RUN python3 -m venv /app/venv
ENV PATH="/app/venv/bin:$PATH"
RUN pip install --no-cache-dir fastapi uvicorn httpx kubernetes

# Copy MOB adapter
COPY src/mob/agent/adapters/pi_adapter.py /app/adapter.py
COPY src/mob/agent/k8s.py /app/k8s.py

EXPOSE 8081

ENTRYPOINT ["python3", "/app/adapter.py"]
